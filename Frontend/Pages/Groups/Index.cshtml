            margin-right: 0;
            margin-bottom: 4px;
        }

        .group-info {
            text-align: center;
            width: 100%;
        }

        .group-name {
            font-size: 10px;
            width: 65px;
            text-align: center;
            margin-bottom: 0;
        }

        .group-meta,
        .group-badge {
            display: none;
