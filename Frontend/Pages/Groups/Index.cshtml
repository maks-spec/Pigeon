        <div class="avatar-section" onclick="document.getElementById('groupAvatarInput').click()" style="text-align: center; margin: 20px 0;">
            <img id="editGroupAvatar" src="/images/default-avatar.png" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 3px solid #667eea;">
