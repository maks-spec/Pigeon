        /* Исправленный отступ для сообщений */
        .messages-container {
            padding-bottom: 100px !important;
        }

        .message {
            max-width: 85%;
            margin-bottom: 10px;
        }

        .message-bubble {
            padding: 8px 12px;
            font-size: 14px;
        }

        .message-sender {
            font-size: 11px;
            margin-bottom: 2px;
        }

        .message-time {
            font-size: 9px;
            margin-top: 2px;
        }
    }
</style>

<div class="groups-container">
