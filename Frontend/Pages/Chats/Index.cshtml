    </div>
</div>

<!-- Оверлей для закрытия меню при клике вне его -->
<div id="menuOverlay" class="menu-overlay" onclick="closeContextMenu()"></div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.js" crossorigin="anonymous"></script>
    <script>
        let currentUser = null;
        let currentChat = null;
        let connection = null;
        let isConnected = false;
        let chatMessages = [];
        let pendingMessages = new Map();
        
        // Переменные для контекстного меню
        let selectedUserForBlock = null;
        let selectedUserNameForBlock = '';

        document.addEventListener('DOMContentLoaded', function() {
            loadCurrentUser();
            initializeSignalR();
            startAutoRefresh();
        });

        // ========== ОСНОВНЫЕ ФУНКЦИИ ЧАТА ==========
        
        function startAutoRefresh() {
            setInterval(async () => {
                if (currentUser) {
                    try {
                        const chatsResponse = await fetch(`http://192.168.1.132:5072/api/chats/user/${currentUser.id}`);
                        if (chatsResponse.ok) {
                            const chats = await chatsResponse.json();
                            displayChatsList(chats);
                        }
                    } catch (error) {
                        console.error('Ошибка обновления чатов:', error);
                    }
                }
            }, 60000);
        }

        function loadCurrentUser() {
            const userId = sessionStorage.getItem('userId');
            const username = sessionStorage.getItem('username');
            const avatarUrl = sessionStorage.getItem('avatarUrl');
            const phoneNumber = sessionStorage.getItem('phoneNumber');

            if (!userId) {
                window.location.href = '/Account/Login';
                return;
            }

            let fullAvatarUrl = '/images/default-avatar.png';
            if (avatarUrl && avatarUrl !== 'null' && avatarUrl !== '') {
                if (avatarUrl.startsWith('http')) {
                    fullAvatarUrl = avatarUrl;
                } else if (avatarUrl.startsWith('/')) {
                    fullAvatarUrl = `http://192.168.1.132:5072${avatarUrl}`;
                } else {
                    fullAvatarUrl = `http://192.168.1.132:5072/uploads/avatars/${avatarUrl}`;
                }
            }

            currentUser = {
                id: parseInt(userId),
                username: username,
                avatarUrl: fullAvatarUrl,
                phoneNumber: phoneNumber || 'Номер не указан'
            };

            document.getElementById('userName').textContent = username;
            document.getElementById('userPhone').textContent = currentUser.phoneNumber;
            
            const avatarImg = document.getElementById('userAvatar');
            avatarImg.src = currentUser.avatarUrl;
            avatarImg.onerror = function() {
                this.src = '/images/default-avatar.png';
            };
            
            loadUserChats();
        }

        async function initializeSignalR() {
            try {
                if (isConnected) {
                    return;
                }
                
                connection = new signalR.HubConnectionBuilder()
                    .withUrl('http://192.168.1.132:5072/chathub')
                    .withAutomaticReconnect()
                    .build();

                connection.on('ReceiveMessage', (message) => {
                    console.log('📨 Получено сообщение:', message);
                    
                    if (!chatMessages.includes(message.id)) {
                        chatMessages.push(message.id);
                        
                        if (message.senderId === currentUser?.id) {
                            removeTempMessageByContent(message.content);
                        }
                        
                        if (currentChat && message.chatId === currentChat.id) {
                            displayMessage(message);
                        }
                    }
                });

                await connection.start();
                isConnected = true;
                console.log('✅ SignalR подключен');
                
                if (currentChat) {
                    await connection.invoke('JoinChat', currentChat.id);
                }
            } catch (err) {
                console.error('❌ Ошибка подключения SignalR:', err);
                isConnected = false;
            }
        }

        async function getOrCreateChat(userId) {
            try {
                const response = await fetch('http://192.168.1.132:5072/api/chats/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        userId1: currentUser.id,
                        userId2: userId
                    })
                });
                
                if (response.ok) {
                    const data = await response.json();
                    return data.chatId;
                }
                return null;
            } catch (error) {
                console.error('Ошибка сети:', error);
                return null;
            }
        }

        async function loadMessages(chatId) {
            try {
                const response = await fetch(`http://192.168.1.132:5072/api/chats/${chatId}/messages`);
                if (response.ok) {
                    const messages = await response.json();
                    const container = document.getElementById('messagesContainer');
                    if (container) {
                        container.innerHTML = '';
                        chatMessages = messages.map(m => m.id);
                        
                        if (messages && messages.length > 0) {
                            messages.forEach(msg => displayMessage(msg));
                            console.log(`✅ Загружено ${messages.length} сообщений`);
                        } else {
                            const emptyMessage = document.createElement('div');
                            emptyMessage.style.textAlign = 'center';
                            emptyMessage.style.color = '#999';
                            emptyMessage.style.padding = '20px';
                            emptyMessage.textContent = 'Нет сообщений. Напишите первое сообщение!';
                            container.appendChild(emptyMessage);
                        }
                        container.scrollTop = container.scrollHeight;
                    }
                }
            } catch (error) {
                console.error('❌ Ошибка загрузки сообщений:', error);
            }
        }

        async function loadUserChats() {
            try {
                const response = await fetch(`http://192.168.1.132:5072/api/chats/user/${currentUser.id}`);
                if (response.ok) {
                    const chats = await response.json();
                    displayChatsList(chats);
                }
            } catch (error) {
                console.error('Ошибка загрузки чатов:', error);
            }
        }

        function displayChatsList(chats) {
            const container = document.getElementById('chatsContainer');
            if (!chats || chats.length === 0) {
                container.innerHTML = `
                    <div style="padding: 20px; text-align: center; color: #999;">
                        У вас пока нет чатов<br>
                        Найдите пользователя по номеру телефона
                    </div>
                `;
                return;
            }
            
            let html = '';
            chats.forEach(chat => {
                if (!chat.otherUser) return;
                
                const lastMessage = chat.lastMessage || { preview: 'Нет сообщений', sentAt: '' };
                const time = lastMessage.sentAt ? new Date(lastMessage.sentAt).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }) : '';
                const avatarUrl = chat.otherUser?.avatarUrl 
                    ? `http://192.168.1.132:5072${chat.otherUser.avatarUrl}` 
                    : '/images/default-avatar.png';
                
                const isActive = currentChat && currentChat.id === chat.chatId ? 'active' : '';
                
                html += `
                    <div class="chat-item ${isActive}" 
                        data-chat-id="${chat.chatId}" 
                        data-user-id="${chat.otherUser.id}"
                        data-username="${chat.otherUser.username}"
                        data-avatar-url="${avatarUrl}">
                        <img src="${avatarUrl}" class="chat-avatar" onerror="this.src='/images/default-avatar.png'" />
                        <div class="chat-info">
                            <div class="chat-name">${chat.otherUser.username}</div>
                            <div class="last-message">${lastMessage.preview || ''}</div>
                        </div>
                        <div class="chat-meta">
                            <div class="chat-time">${time}</div>
                        </div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
            
            document.querySelectorAll('.chat-item').forEach(item => {
                let pressTimer;
                let isLongPress = false;
                let startX = 0;
                let startY = 0;
                let isScrolling = false;
                
                item.addEventListener('click', function(e) {
                    if (isLongPress || isScrolling) {
                        isLongPress = false;
                        isScrolling = false;
                        return;
                    }
                    
                    const chatId = this.dataset.chatId;
                    const userId = this.dataset.userId;
                    const username = this.dataset.username;
                    const avatarUrl = this.dataset.avatarUrl;
                    
                    selectChat(parseInt(chatId), parseInt(userId), username, avatarUrl);
                });
                
                item.addEventListener('contextmenu', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    const userId = this.dataset.userId;
                    const username = this.dataset.username;
                    openContextMenu(e, parseInt(userId), username);
                });
                
                item.addEventListener('touchstart', function(e) {
                    isLongPress = false;
                    isScrolling = false;
                    const touch = e.touches[0];
                    startX = touch.pageX;
                    startY = touch.pageY;
                    
                    const userId = this.dataset.userId;
                    const username = this.dataset.username;
                    
                    pressTimer = setTimeout(() => {
                        isLongPress = true;
                        if (navigator.vibrate) {
                            navigator.vibrate(50);
                        }
                        
                        const fakeEvent = {
                            pageX: startX,
                            pageY: startY,
                            preventDefault: () => {},
                            stopPropagation: () => {}
                        };
                        
                        openContextMenu(fakeEvent, parseInt(userId), username);
                    }, 500);
                });
                
                item.addEventListener('touchmove', function(e) {
                    clearTimeout(pressTimer);
                    
                    if (!isLongPress) {
                        const touch = e.touches[0];
                        const diffX = Math.abs(touch.pageX - startX);
                        const diffY = Math.abs(touch.pageY - startY);
                        
                        if (diffX > 10 || diffY > 10) {
                            isScrolling = true;
                        }
                    }
                });
                
                item.addEventListener('touchend', function(e) {
                    clearTimeout(pressTimer);
                    
                    if (!isLongPress && !isScrolling) {
                        const chatId = this.dataset.chatId;
                        const userId = this.dataset.userId;
                        const username = this.dataset.username;
                        const avatarUrl = this.dataset.avatarUrl;
                        
                        selectChat(parseInt(chatId), parseInt(userId), username, avatarUrl);
                    }
                    
                    isLongPress = false;
                    isScrolling = false;
                });
                
                item.addEventListener('touchcancel', function() {
                    clearTimeout(pressTimer);
                    isLongPress = false;
                    isScrolling = false;
                });
            });
        }

        async function selectChat(chatId, userId, username, avatarUrl) {
            try {
                const checkResponse = await fetch(`http://192.168.1.132:5072/api/block/check?userId=${currentUser.id}&blockedUserId=${userId}`);
                if (checkResponse.ok) {
                    const data = await checkResponse.json();
                    if (data.isBlocked) {
                        alert('Этот пользователь заблокирован');
                        return;
                    }
                }
            } catch (error) {
                console.error('Ошибка проверки блокировки:', error);
            }

            if (currentChat && currentChat.id === chatId) {
                return;
            }

            if (currentChat && connection && isConnected) {
                try {
                    await connection.invoke('LeaveChat', currentChat.id);
                } catch (err) {
                    console.error('Ошибка при выходе из чата:', err);
                }
            }

            currentChat = {
                id: chatId,
                userId: userId,
                username: username,
                avatarUrl: avatarUrl
            };

            const noChatElement = document.getElementById('noChatSelected');
            if (noChatElement) {
                noChatElement.style.display = 'none';
            }
            
            document.getElementById('chatArea').innerHTML = `
                <div class="chat-header">
                    <img src="${currentChat.avatarUrl}" class="chat-header-avatar" 
                        onerror="this.src='/images/default-avatar.png'" />
                    <div class="chat-header-name">${currentChat.username}</div>
                </div>
                <div class="messages-container" id="messagesContainer" style="padding-bottom: 120px;"></div>
            `;

            await loadMessages(chatId);
            
            // Удаляем старое поле ввода если есть
            const oldInput = document.getElementById('fixed-message-input-area');
            if (oldInput) oldInput.remove();
            
            // Создаем новое поле ввода
            const inputContainer = document.createElement('div');
            inputContainer.className = 'fixed-message-input-area';
            inputContainer.id = 'fixed-message-input-area';
            // Принудительно задаём прозрачный фон (гарантия)
            inputContainer.style.background = 'transparent';
            inputContainer.style.backgroundColor = 'transparent';
            
            inputContainer.innerHTML = `
                <input type="file" id="fixed-media-input" accept="image/*,video/*" style="display: none;" onchange="handleFixedMedia(this)" />
                <button class="attach-btn" onclick="document.getElementById('fixed-media-input').click()">📎</button>
                <input type="text" id="fixed-message-input" class="message-input" placeholder="Напишите сообщение..." />
                <button class="send-btn" onclick="sendFixedMessage()">➤</button>
            `;
            
            document.body.appendChild(inputContainer);
            
            document.getElementById('fixed-message-input').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    sendFixedMessage();
                }
            });

            if (connection && isConnected) {
                try {
                    await connection.invoke('JoinChat', chatId);
                } catch (err) {
                    console.error('Ошибка присоединения к чату:', err);
                }
            }

            loadUserChats();
        }

        function updateMessageInput() {
            const oldInput = document.getElementById('fixed-message-input-area');
            if (oldInput) oldInput.remove();
            
            const inputContainer = document.createElement('div');
            inputContainer.className = 'fixed-message-input-area';
            inputContainer.id = 'fixed-message-input-area';
            // Принудительно задаём прозрачный фон
            inputContainer.style.background = 'transparent';
            inputContainer.style.backgroundColor = 'transparent';
            
            inputContainer.innerHTML = `
                <input type="file" id="fixed-media-input" accept="image/*,video/*" style="display: none;" onchange="handleFixedMedia(this)" />
                <button class="attach-btn" onclick="document.getElementById('fixed-media-input').click()">📎</button>
                <input type="text" id="fixed-message-input" class="message-input" placeholder="Напишите сообщение..." />
                <button class="send-btn" onclick="sendFixedMessage()">➤</button>
            `;
            
            document.body.appendChild(inputContainer);
            
            document.getElementById('fixed-message-input').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    sendFixedMessage();
                }
            });
        }

        window.sendFixedMessage = function() {
            const input = document.getElementById('fixed-message-input');
            const message = input.value.trim();
            
            if (!message || !currentChat || !currentUser) {
                console.error('❌ Не все данные для отправки');
                return;
            }
            
            input.value = '';
            
            const tempId = `temp_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
            
            pendingMessages.set(tempId, {
                content: message,
                timestamp: Date.now()
            });
            
            displayMessage({
                id: tempId,
                content: message,
                senderId: currentUser.id,
                sentAt: new Date(),
                messageType: 'text',
                isTemp: true
            }, true);
            
            if (connection && isConnected) {
                connection.invoke('SendMessage', currentChat.id, null, currentUser.id, message, 'text')
                    .catch(err => {
                        console.error('❌ Ошибка отправки через SignalR:', err);
                        sendMessageViaRest(message, tempId);
                    });
            } else {
                sendMessageViaRest(message, tempId);
            }
        };
        
        async function sendMessageViaRest(message, tempId) {
            try {
                const response = await fetch('http://192.168.1.132:5072/api/chats/send-message', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        chatId: currentChat.id,
                        senderId: currentUser.id,
                        content: message,
                        messageType: 'text'
                    })
                });

                if (!response.ok) {
                    throw new Error('Ошибка отправки');
                }

                const savedMessage = await response.json();
                removeTempMessage(tempId);
                
            } catch (error) {
                console.error('❌ Ошибка отправки через REST:', error);
                removeTempMessage(tempId);
                alert('❌ Не удалось отправить сообщение');
            }
        }
        
        function removeTempMessage(tempId) {
            const container = document.getElementById('messagesContainer');
            const tempMessages = container.querySelectorAll('.message');
            for (let msg of tempMessages) {
                if (msg.dataset.tempId === tempId) {
                    msg.remove();
                    pendingMessages.delete(tempId);
                    break;
                }
            }
        }
        
        function removeTempMessageByContent(content) {
            const container = document.getElementById('messagesContainer');
            const tempMessages = container.querySelectorAll('.message');
            for (let msg of tempMessages) {
                if (msg.style.opacity === '0.7') {
                    const bubble = msg.querySelector('.message-bubble');
                    if (bubble && bubble.textContent === content) {
                        msg.remove();
                        break;
                    }
                }
            }
        }
        
        window.handleFixedMedia = function(input) {
            if (!input.files || !input.files[0] || !currentChat) return;
            
            const file = input.files[0];
            const formData = new FormData();
            formData.append('chatId', currentChat.id);
            formData.append('senderId', currentUser.id);
            formData.append('file', file);
            
            const tempId = `temp_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
            const isImage = file.type.startsWith('image/');
            const isVideo = file.type.startsWith('video/');
            
            let tempContent;
            if (isImage) {
                tempContent = URL.createObjectURL(file);
            } else if (isVideo) {
                tempContent = URL.createObjectURL(file);
            } else {
                tempContent = '📎 Файл';
            }
            
            pendingMessages.set(tempId, {
                content: tempContent,
                timestamp: Date.now(),
                isMedia: true
            });
            
            displayMessage({
                id: tempId,
                content: tempContent,
                senderId: currentUser.id,
                sentAt: new Date(),
                messageType: isImage ? 'image' : (isVideo ? 'video' : 'file'),
                isTemp: true
            }, true);
            
            fetch('http://192.168.1.132:5072/api/chats/send-media', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Ошибка загрузки');
                }
                return response.json();
            })
            .then(message => {
                removeTempMessage(tempId);
                
                if (tempContent.startsWith('blob:')) {
                    URL.revokeObjectURL(tempContent);
                }
                
                const fullMessage = {
                    ...message,
                    content: `http://192.168.1.132:5072${message.content}`
                };
                
                if (!chatMessages.includes(message.id)) {
                    chatMessages.push(message.id);
                    displayMessage(fullMessage);
                }
            })
            .catch(error => {
                console.error('Ошибка отправки медиа:', error);
                removeTempMessage(tempId);
                
                if (tempContent.startsWith('blob:')) {
                    URL.revokeObjectURL(tempContent);
                }
                
                alert('❌ Ошибка при отправке файла');
            });
            
            input.value = '';
        };

        async function searchUsers(query) {
            if (!query || query.length < 5) {
                document.getElementById('searchResults').innerHTML = '';
                return;
            }

            let phoneNumber = query;
            if (!query.startsWith('+')) {
                phoneNumber = '+7' + query.replace(/[^0-9]/g, '');
            }

            try {
                const response = await fetch(`http://192.168.1.132:5072/api/users/search?phoneNumber=${encodeURIComponent(phoneNumber)}`);
                const resultsDiv = document.getElementById('searchResults');
                
                if (response.ok) {
                    const user = await response.json();
                    if (user.id === currentUser.id) {
                        resultsDiv.innerHTML = '<div class="search-result-item">Это ваш номер</div>';
                        return;
                    }
                    
                    const avatarUrl = user.avatarUrl 
                        ? `http://192.168.1.132:5072${user.avatarUrl}` 
                        : '/images/default-avatar.png';
                    
                    resultsDiv.innerHTML = `
                        <div class="search-result-item">
                            <img src="${avatarUrl}" class="result-avatar" 
                                 onerror="this.src='/images/default-avatar.png'" />
                            <div class="result-info">
                                <div class="result-name">${user.username}</div>
                                <div class="result-phone">${user.phoneNumber}</div>
                            </div>
                            <button class="start-chat-btn" onclick="startChat(${user.id}, '${user.username}', '${avatarUrl}')">
                                Написать
                            </button>
                        </div>
                    `;
                } else {
                    resultsDiv.innerHTML = '<div class="search-result-item">Пользователь не найден</div>';
                }
            } catch (error) {
                console.error('Ошибка поиска:', error);
            }
        }

        async function startChat(userId, username, avatarUrl) {
            const chatId = await getOrCreateChat(userId);
            if (chatId) {
                await selectChat(chatId, userId, username, avatarUrl);
                document.getElementById('searchResults').innerHTML = '';
                document.getElementById('searchInput').value = '';
            } else {
                alert('Не удалось создать чат');
            }
        }

        function displayMessage(message, isTempForSender = false) {
            const container = document.getElementById('messagesContainer');
            if (!container) return;

            const isOwn = message.senderId === currentUser.id;
            
            if (isOwn && !message.isTemp && !isTempForSender) {
                removeTempMessageByContent(message.content);
            }

            const time = message.isTemp ? 'Отправка...' : new Date(message.sentAt).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });

            let contentHtml = '';
            if (message.messageType === 'image') {
                let imgSrc = message.content;
                if (!imgSrc.startsWith('http') && !imgSrc.startsWith('blob:')) {
                    imgSrc = `http://192.168.1.132:5072${imgSrc}`;
                }
                contentHtml = `<img src="${imgSrc}" style="max-width: 100%; max-height: 300px; border-radius: 10px; cursor: pointer; ${message.isTemp ? 'opacity: 0.7;' : ''}" onclick="window.open(this.src)" />`;
            } else if (message.messageType === 'video') {
                let videoSrc = message.content;
                if (!videoSrc.startsWith('http') && !videoSrc.startsWith('blob:')) {
                    videoSrc = `http://192.168.1.132:5072${videoSrc}`;
                }
                contentHtml = `<video controls style="max-width: 100%; max-height: 300px; border-radius: 10px; ${message.isTemp ? 'opacity: 0.7;' : ''}"><source src="${videoSrc}"></video>`;
            } else if (message.messageType === 'file') {
                contentHtml = `📎 <a href="${message.content}" target="_blank">Файл</a>`;
            } else {
                contentHtml = message.content;
            }

            const messageElement = document.createElement('div');
            messageElement.className = `message ${isOwn ? 'own' : 'other'}`;
            messageElement.dataset.messageId = message.id;
            if (message.isTemp) {
                messageElement.dataset.tempId = message.id;
                messageElement.style.opacity = '0.7';
            }
            
            messageElement.innerHTML = `
                <div class="message-bubble">${contentHtml}</div>
                <div class="message-time">${time}</div>
            `;

            container.appendChild(messageElement);
            container.scrollTop = container.scrollHeight;
        }

        function openProfileEditor() {
            window.location.href = '/Account/Profile';
        }

        function closeProfileEditor() {
            document.getElementById('profileModal').style.display = 'none';
        }

        function previewAvatar(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    document.getElementById('modalAvatar').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        async function saveProfile() {
            const newUsername = document.getElementById('editUsername').value.trim();
            const avatarInput = document.getElementById('avatarInput');
            
            if (!newUsername) {
                alert('Введите имя пользователя');
                return;
            }

            const formData = new FormData();
            formData.append('username', newUsername);
            
            if (avatarInput.files && avatarInput.files[0]) {
                formData.append('avatar', avatarInput.files[0]);
            }

            try {
                const response = await fetch(`http://192.168.1.132:5072/api/users/${currentUser.id}/profile`, {
                    method: 'PUT',
                    body: formData
                });

                if (response.ok) {
                    const result = await response.json();
                    
                    currentUser.username = result.username;
                    if (result.avatarUrl) {
                        let fullAvatarUrl;
                        if (result.avatarUrl.startsWith('http')) {
                            fullAvatarUrl = result.avatarUrl;
                        } else if (result.avatarUrl.startsWith('/')) {
                            fullAvatarUrl = `http://192.168.1.132:5072${result.avatarUrl}`;
                        } else {
                            fullAvatarUrl = `http://192.168.1.132:5072/uploads/avatars/${result.avatarUrl}`;
                        }
                        currentUser.avatarUrl = fullAvatarUrl;
                        sessionStorage.setItem('avatarUrl', result.avatarUrl);
                    }
                    
                    sessionStorage.setItem('username', result.username);
                    
                    document.getElementById('userName').textContent = result.username;
                    document.getElementById('userAvatar').src = currentUser.avatarUrl;
                    
                    closeProfileEditor();
                    alert('Профиль успешно обновлен');
                } else {
                    const error = await response.json();
                    alert('Ошибка: ' + (error.message || 'Не удалось обновить профиль'));
                }
            } catch (error) {
                console.error('Ошибка сохранения профиля:', error);
                alert('Ошибка соединения с сервером');
            }
        }

        function openContextMenu(event, userId, username) {
            event.preventDefault();
            event.stopPropagation();
            
            selectedUserForBlock = userId;
            selectedUserNameForBlock = username;
            
            const menu = document.getElementById('blockMenu');
            const overlay = document.getElementById('menuOverlay');
            
            let x = event.pageX;
            let y = event.pageY;
            
            const menuWidth = 200;
            const menuHeight = 100;
            const windowWidth = window.innerWidth;
            const windowHeight = window.innerHeight;
            
            if (x + menuWidth > windowWidth) {
                x = windowWidth - menuWidth - 10;
            }
            if (y + menuHeight > windowHeight) {
                y = windowHeight - menuHeight - 10;
            }
            
            menu.style.left = x + 'px';
            menu.style.top = y + 'px';
            menu.style.display = 'block';
            overlay.style.display = 'block';
            
            const blockItem = menu.querySelector('.context-menu-item:first-child');
            blockItem.innerHTML = `<span>🚫</span> Заблокировать ${username}`;
        }

        function closeContextMenu() {
            document.getElementById('blockMenu').style.display = 'none';
            document.getElementById('menuOverlay').style.display = 'none';
            selectedUserForBlock = null;
        }

        async function blockUser() {
            if (!selectedUserForBlock || !currentUser) {
                closeContextMenu();
                return;
            }
            
            if (!confirm(`Вы уверены, что хотите заблокировать пользователя ${selectedUserNameForBlock}? Чат будет удален.`)) {
                closeContextMenu();
                return;
            }
            
            try {
                const response = await fetch('http://192.168.1.132:5072/api/block/block', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        userId: currentUser.id,
                        blockedUserId: selectedUserForBlock
                    })
                });
                
                if (response.ok) {
                    alert(`✅ Пользователь ${selectedUserNameForBlock} заблокирован`);
                    
                    if (currentChat && currentChat.userId === selectedUserForBlock) {
                        document.getElementById('chatArea').innerHTML = `
                            <div class="no-chat-selected" id="noChatSelected">
                                <div class="no-chat-icon">💬</div>
                                <div class="no-chat-text">Выберите чат</div>
                                <div class="no-chat-hint">Найдите пользователя и начните общение</div>
                            </div>
                        `;
                        
                        const input = document.getElementById('fixed-message-input-area');
                        if (input) input.remove();
                        
                        currentChat = null;
                    }
                    
                    await loadUserChats();
                } else {
                    const error = await response.json();
                    alert('❌ ' + (error.message || 'Ошибка блокировки'));
                }
            } catch (error) {
                console.error('Ошибка:', error);
                alert('❌ Ошибка соединения с сервером');
            }
            
            closeContextMenu();
        }

        function refreshPage() {
            const button = document.querySelector('.refresh-button');
            button.style.transform = 'rotate(180deg) scale(0.95)';
            button.style.opacity = '0.8';
            
            setTimeout(() => {
                window.location.reload();
            }, 200);
        }

        function goToGroups() {
            window.location.href = '/Groups';
        }
    </script>
}